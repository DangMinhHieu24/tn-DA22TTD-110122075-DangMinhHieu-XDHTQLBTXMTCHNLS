generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TECHNICIAN
  CUSTOMER
}

enum WorkOrderStatus {
  PENDING       // Chờ xử lý
  IN_PROGRESS   // Đang thực hiện
  INSPECTION    // Kiểm tra
  COMPLETED     // Hoàn thành
  PAID          // Đã thanh toán
  CANCELLED     // Đã hủy
}

enum WorkPriority {
  NORMAL
  URGENT
}

enum ServiceType {
  MAINTENANCE      // Bảo dưỡng định kỳ
  BATTERY_CHECK    // Kiểm tra pin/sạc
  BRAKES_TIRES     // Phanh & Lốp
  OTHER_REPAIR     // Sửa chữa khác
}

enum PhotoType {
  INTAKE
  AFTER_REPAIR
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  phoneNumber String?  @unique @map("phone")
  name        String
  password    String
  role        UserRole @default(CUSTOMER)
  loyaltyPoints Int    @default(0) @map("loyalty_points")
  avatarUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  ownedVehicles     Vehicle[]    @relation("VehicleOwner")
  assignedWorkOrders WorkOrder[] @relation("AssignedTechnician")
  createdWorkOrders  WorkOrder[] @relation("CreatedByAdmin")
  appointments       Appointment[]

  @@map("users")
}

model Vehicle {
  id            String   @id @default(uuid())
  licensePlate  String   @unique @map("license_plate") // Biển số xe (VD: 29A-123.45)
  brand         String?  // Hãng xe (VD: VinFast, Yadea, Pega)
  model         String   // Model xe (VD: VinFast Klara S)
  color         String?  // Màu xe
  imageUrl      String?  @map("image_url")
  manufactureYear Int?   @map("manufacturer_year") // Năm sản xuất
  qrCode        String?  @unique @map("qr_code") // Mã QR của xe
  warrantyExpiry DateTime? @map("warranty_expiry") // Ngày hết hạn bảo hành
  currentKm     Int?     @map("current_odometer") // Số km hiện tại (cập nhật sau mỗi lần sửa)
  
  // Relations
  ownerId       String   @map("owner_id")
  owner         User     @relation("VehicleOwner", fields: [ownerId], references: [id])
  workOrders    WorkOrder[]

  maintenanceLogs MaintenanceLog[]
  warranties     Warranty[]
  partWarranties PartWarranty[]
  appointments   Appointment[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("vehicles")
}

model WorkOrder {
  id                String          @id @default(uuid())
  orderNumber       String          @unique // Mã phiếu (auto-generated)
  
  // Vehicle info
  vehicleId         String          @map("vehicle_id")
  vehicle           Vehicle         @relation(fields: [vehicleId], references: [id])
  
  // Status & Priority
  status            WorkOrderStatus @default(PENDING)
  priority          WorkPriority    @default(NORMAL)

  totalPrice        Float?          @map("total_price")
  
  // Services
  services          WorkOrderService[]
  notes             String?         // Ghi chú thêm
  
  // Assignment
  technicianId      String?         @map("staff_id")
  technician        User?           @relation("AssignedTechnician", fields: [technicianId], references: [id])
  estimatedHours    Float?          // Ước tính thời gian (giờ)
  scheduledTime     String?         // Thời gian hẹn (VD: "14:00")
  
  // Photos
  photos            WorkOrderPhoto[]
  
  // Tracking
  createdById       String          @map("created_by_id")
  createdBy         User            @relation("CreatedByAdmin", fields: [createdById], references: [id])
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt
  completedAt       DateTime?       @map("completed_at")

  partsUsed         PartsUsed[]
  partWarranties    PartWarranty[]
  maintenanceLog    MaintenanceLog?

  @@map("work_orders")
}

model WorkOrderService {
  id            String      @id @default(uuid())
  workOrderId   String      @map("order_id")
  workOrder     WorkOrder   @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  serviceType   ServiceType
  description   String?     // Mô tả chi tiết dịch vụ
  serviceName   String?     @map("service_name")
  price         Float?      @map("price")
  isDone        Boolean     @default(false) @map("is_done")
  note          String?     @map("note")

  createdAt     DateTime    @default(now())

  @@map("repair_items")
}

model WorkOrderPhoto {
  id            String    @id @default(uuid())
  workOrderId   String
  workOrder     WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  photoUrl      String    // URL ảnh (Firebase Storage hoặc local)
  photoType     PhotoType @default(INTAKE)
  description   String?   // Mô tả ảnh (VD: "Xước góc trước bên trái")
  
  createdAt     DateTime  @default(now())

  @@map("work_order_photos")
}

model Inventory {
  id           String  @id @default(uuid())
  partName     String  @map("part_name")
  imageUrl     String? @map("image_url")
  quantity     Int     @default(0)
  minThreshold Int     @map("min_threshold")
  unitPrice    Float   @map("unit_price")
  sellPrice    Float   @map("sell_price")
  warrantyDays Int     @default(0) @map("warranty_days")

  partsUsed    PartsUsed[]
  partWarranties PartWarranty[]

  @@map("inventory")
}

model PartsUsed {
  id         String    @id @default(uuid())
  workOrderId String   @map("order_id")
  workOrder  WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  partId     String   @map("part_id")
  part       Inventory @relation(fields: [partId], references: [id])
  quantity   Int
  unitPrice  Float    @map("unit_price")
  partWarranty PartWarranty?

  @@map("parts_used")
}

model PartWarranty {
  id           String   @id @default(uuid())
  partUsedId   String   @unique @map("part_used_id")
  partUsed     PartsUsed @relation(fields: [partUsedId], references: [id], onDelete: Cascade)
  partId       String   @map("part_id")
  part         Inventory @relation(fields: [partId], references: [id])
  workOrderId  String   @map("work_order_id")
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id])
  vehicleId    String   @map("vehicle_id")
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])
  warrantyDays Int      @map("warranty_days")
  startDate    DateTime @default(now()) @map("start_date")
  expiryDate   DateTime @map("expiry_date")

  @@map("part_warranties")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Appointment {
  id          String   @id @default(uuid())
  customerId  String   @map("customer_id")
  customer    User     @relation(fields: [customerId], references: [id])
  vehicleId   String?  @map("vehicle_id")
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  scheduledAt DateTime @map("scheduled_at")
  serviceType String?  @map("service_type")
  notes       String?
  status      AppointmentStatus @default(PENDING)

  @@map("appointments")
}

model MaintenanceLog {
  id             String   @id @default(uuid())
  vehicleId      String   @map("vehicle_id")
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id])
  workOrderId    String?  @unique @map("work_order_id")
  workOrder      WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  odometerKm     Int      @map("odometer_km")
  serviceType    String?  @map("service_type")
  serviceSummary String?  @map("service_summary")
  nextServiceKm  Int?     @map("next_service_km")
  nextServiceDate DateTime? @map("next_service_date")
  notes          String?
  performedAt    DateTime @default(now()) @map("performed_at")

  @@index([vehicleId, performedAt])
  @@map("maintenance_logs")
}

model Warranty {
  id           String   @id @default(uuid())
  vehicleId    String   @map("vehicle_id")
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])
  warrantyType String   @map("warranty_type")
  startDate    DateTime @map("start_date")
  expiryDate   DateTime @map("expiry_date")
  terms        String?
  issuedBy     String?  @map("issued_by")

  @@map("warranties")
}
